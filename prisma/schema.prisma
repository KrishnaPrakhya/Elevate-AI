// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String           @id @default(uuid())
  clerkUserId                String           @unique
  email                      String           @unique
  name                       String?
  imageUrl                   String?
  industry                   String?
  targetRole                 String?          // Centralized target role for career focus
  industryInsight            IndustryInsight? @relation(fields: [industry], references: [industry])
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  bio                        String?
  targetRole                 String?
  googleCalendarRefreshToken String?          @db.Text
  googleCalendarConnectedAt  DateTime?
  experience                 Int?
  skills                     String[]
  assessments                Assessments[]
  resume                     Resume?
  coverLetter                CoverLetter[]
  ChatMessage                ChatMessage[]

  // Academy relations
  enrollments      Enrollment[]
  dailyGoals       DailyGoal[]
  streak           Streak?
  userAchievements UserAchievement[]
  submissions      Submission[]
  cohortMembership CohortMember[]
  emailPreference  EmailPreference?
  reminders        Reminder[]
  mentor           Mentor?
  skillProgress    UserSkillProgress[]
  simulations      SimulationAttempt[]
  portfolio        PortfolioArtifact[]

  // Agentic AI relations
  pendingActions  PendingAction[]
  executedActions ExecutedAction[]
  jobApplications JobApplication[]
  calendarEvents  CalendarEvent[]
}

model Resume {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  content   String   @db.Text
  atsScore  Float?
  feedback  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assessments {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  quizScore      Float
  questions      Json[]
  category       String
  improvementTip String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model CoverLetter {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  content        String
  jobDescription String?
  companyName    String?
  jobTitle       String
  templateId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model IndustryInsight {
  id           String      @id @default(cuid())
  industry     String      @unique
  users        User[]
  salaryRanges Json[]
  growthRate   Float
  demandLevel  DemandLevel
  topSkills    String[]

  marketOutLook MarketOutLook
  keyTrends     String[]

  recommendedSkills String[]

  lastUpdated            DateTime                 @default(now())
  nextUpdated            DateTime
  IndustryInsightHistory IndustryInsightHistory[]
  ChatMessage            ChatMessage[]

  @@index([industry])
}

model IndustryInsightHistory {
  id                String          @id @default(cuid())
  industryInsightId String
  industryInsight   IndustryInsight @relation(fields: [industryInsightId], references: [id])
  salaryRanges      Json[]
  growthRate        Float
  demandLevel       DemandLevel
  topSkills         String[]
  marketOutLook     MarketOutLook
  keyTrends         String[]
  recommendedSkills String[]
  updatedAt         DateTime        @default(now())

  @@index([industryInsightId, updatedAt])
}

model ChatMessage {
  messageId         String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id])
  content           String
  createdAt         DateTime         @default(now())
  IndustryInsight   IndustryInsight? @relation(fields: [industryInsightId], references: [id])
  industryInsightId String?

  @@index([userId])
}

enum DemandLevel {
  HIGH
  MEDIUM
  LOW
}

enum MarketOutLook {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

// ============================================
// ACADEMY - Learning & Development
// ============================================

model LearningPath {
  id             String    @id @default(cuid())
  title          String
  description    String    @db.Text
  industry       String?
  level          PathLevel @default(BEGINNER)
  icon           String?
  bannerUrl      String?
  estimatedHours Int?
  isPublished    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  modules     Module[]
  enrollments Enrollment[]

  @@index([industry])
  @@index([isPublished])
}

enum PathLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Module {
  id             String       @id @default(cuid())
  learningPathId String
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  title          String
  description    String       @db.Text
  order          Int
  estimatedHours Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lessons     Lesson[]
  assignments Assignment[]

  @@index([learningPathId])
}

model Lesson {
  id               String     @id @default(cuid())
  moduleId         String
  module           Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title            String
  content          String     @db.Text
  videoUrl         String?
  order            Int
  type             LessonType @default(THEORY)
  estimatedMinutes Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  progress    LessonProgress[]
  submissions Submission[]

  @@index([moduleId])
}

enum LessonType {
  THEORY
  VIDEO
  QUIZ
  ASSIGNMENT
  PROJECT
  LIVE_SESSION
}

model Enrollment {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPathId  String
  learningPath    LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  enrolledAt      DateTime     @default(now())
  completedAt     DateTime?
  progress        Float        @default(0)
  currentModuleId String?
  currentLessonId String?
  lastAccessedAt  DateTime     @default(now())

  lessonProgress LessonProgress[]

  @@unique([userId, learningPathId])
  @@index([userId])
  @@index([learningPathId])
}

model LessonProgress {
  id               String         @id @default(cuid())
  enrollmentId     String
  enrollment       Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId         String
  lesson           Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status           ProgressStatus @default(NOT_STARTED)
  timeSpentMinutes Int            @default(0)
  completedAt      DateTime?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  REVIEW
}

// ============================================
// ASSIGNMENTS & SUBMISSIONS
// ============================================

model Assignment {
  id                  String    @id @default(cuid())
  moduleId            String
  module              Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title               String
  description         String    @db.Text
  dueDate             DateTime?
  maxScore            Int       @default(100)
  passingScore        Int       @default(60)
  allowLateSubmission Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  submissions Submission[]

  @@index([moduleId])
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  lessonId     String?
  lesson       Lesson?    @relation(fields: [lessonId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content      String     @db.Text
  attachments  Json?
  score        Int?
  feedback     String?
  submittedAt  DateTime   @default(now())
  gradedAt     DateTime?
  isLate       Boolean    @default(false)

  @@index([assignmentId])
  @@index([userId])
}

// ============================================
// DAILY GOALS & STREAKS
// ============================================

model DailyGoal {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                 DateTime @db.Date
  targetMinutes        Int      @default(30)
  actualMinutes        Int      @default(0)
  lessonsCompleted     Int      @default(0)
  assignmentsCompleted Int      @default(0)
  quizzesCompleted     Int      @default(0)
  streakDays           Int      @default(0)
  bonusEarned          Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model Streak {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  weeklyGoalMet    Int       @default(0)
  monthlyGoalMet   Int       @default(0)
  totalDaysActive  Int       @default(0)
  updatedAt        DateTime  @updatedAt

  @@index([userId])
}

// ============================================
// ACHIEVEMENTS & LEADERBOARD
// ============================================

model Achievement {
  id          String              @id @default(cuid())
  title       String
  description String
  icon        String
  category    AchievementCategory
  points      Int                 @default(10)
  criteria    Json
  threshold   Int
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())

  userAchievements UserAchievement[]

  @@index([category])
  @@index([isActive])
}

enum AchievementCategory {
  LEARNING
  STREAK
  ASSIGNMENT
  QUIZ
  MILESTONE
  COMMUNITY
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime    @default(now())
  progress      Int         @default(0)

  @@unique([userId, achievementId])
  @@index([userId])
}

model Leaderboard {
  id        String          @id @default(cuid())
  type      LeaderboardType
  period    String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime        @default(now())

  entries LeaderboardEntry[]

  @@index([type, period])
}

enum LeaderboardType {
  WEEKLY
  MONTHLY
  ALL_TIME
}

model LeaderboardEntry {
  id            String      @id @default(cuid())
  leaderboardId String
  leaderboard   Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  userId        String
  points        Int         @default(0)
  rank          Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([leaderboardId, userId])
  @@index([leaderboardId, rank])
}

// ============================================
// COHORTS & MENTORSHIP
// ============================================

model Cohort {
  id          String   @id @default(cuid())
  name        String
  description String?
  industry    String?
  startsAt    DateTime
  endsAt      DateTime
  maxMembers  Int      @default(30)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  CohortMember[]
  mentorId String?

  @@index([industry])
  @@index([isActive])
}

model CohortMember {
  id       String     @id @default(cuid())
  cohortId String
  cohort   Cohort     @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     CohortRole @default(STUDENT)
  joinedAt DateTime   @default(now())

  @@unique([cohortId, userId])
  @@index([cohortId])
}

enum CohortRole {
  STUDENT
  LEADER
  MENTOR
}

model Mentor {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  expertise       String[]
  yearsExperience Int?
  rating          Float?
  totalSessions   Int      @default(0)
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions MentorshipSession[]

  @@index([userId])
}

model MentorshipSession {
  id              String        @id @default(cuid())
  mentorId        String
  mentor          Mentor        @relation(fields: [mentorId], references: [id])
  studentId       String
  scheduledAt     DateTime
  durationMinutes Int           @default(30)
  status          SessionStatus @default(SCHEDULED)
  notes           String?
  feedback        String?
  rating          Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([mentorId])
  @@index([studentId])
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

// ============================================
// EMAIL PREFERENCES & SENT EMAILS
// ============================================

model EmailPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyDigest        Boolean  @default(true)
  weeklyProgress     Boolean  @default(true)
  streakReminders    Boolean  @default(true)
  deadlineAlerts     Boolean  @default(true)
  achievementAlerts  Boolean  @default(true)
  cohortMessages     Boolean  @default(true)
  mentorUpdates      Boolean  @default(true)
  leaderboardUpdates Boolean  @default(false)
  emailTime          String   @default("09:00")
  timezone           String   @default("UTC")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sentEmails SentEmail[]

  @@index([userId])
}

model SentEmail {
  id           String          @id @default(cuid())
  preferenceId String
  preference   EmailPreference @relation(fields: [preferenceId], references: [id])
  type         EmailType
  subject      String
  body         String          @db.Text
  sentAt       DateTime        @default(now())
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  metadata     Json?

  @@index([preferenceId])
  @@index([sentAt])
}

enum EmailType {
  DAILY_DIGEST
  WEEKLY_PROGRESS
  STREAK_REMINDER
  DEADLINE_ALERT
  ACHIEVEMENT_UNLOCKED
  COHORT_WELCOME
  MENTOR_ASSIGNED
  LEADERBOARD_UPDATE
  COURSE_RECOMMENDATION
  INACTIVITY_ALERT
  PERSONALIZED_TIP
}

// ============================================
// SMART REMINDERS (Agentic Mail)
// ============================================

model Reminder {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         ReminderType
  title        String
  message      String         @db.Text
  scheduledFor DateTime
  sentAt       DateTime?
  status       ReminderStatus @default(PENDING)
  priority     Priority       @default(MEDIUM)
  metadata     Json?
  createdAt    DateTime       @default(now())

  @@index([userId, status])
  @@index([scheduledFor])
}

enum ReminderType {
  LEARNING_GOAL
  ASSIGNMENT_DUE
  STREAK_CHECK
  WEEKLY_REVIEW
  PEER_MOTIVATION
  MILESTONE_CELEBRATION
  STREAK_NUDGE
  COLD_START
  MAINTENANCE
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================ 
// EXPERIENCE SIMULATOR & HYPER-PATH 
// ============================================
model SkillNode {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String
  description String?
  createdAt   DateTime @default(now())

  userProgress UserSkillProgress[]
  requiredFor  SimulationScenario[]
}

model UserSkillProgress {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId       String
  skill         SkillNode @relation(fields: [skillId], references: [id], onDelete: Cascade)
  masteryLevel  Int       @default(0)
  lastPracticed DateTime  @default(now())

  @@unique([userId, skillId])
  @@index([userId])
}

model SimulationScenario {
  id              String         @id @default(cuid())
  title           String
  description     String         @db.Text
  difficulty      PathLevel      @default(BEGINNER)
  type            SimulationType
  aiPrompt        String         @db.Text
  successCriteria String         @db.Text
  primarySkillId  String?
  primarySkill    SkillNode?     @relation(fields: [primarySkillId], references: [id])
  createdAt       DateTime       @default(now())

  attempts SimulationAttempt[]
}

enum SimulationType {
  TECHNICAL
  SOFT_SKILL
  NEGOTIATION
  DEBUGGING
  SYSTEM_DESIGN
}

model SimulationAttempt {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenarioId  String
  scenario    SimulationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  status      AttemptStatus      @default(IN_PROGRESS)
  transcript  Json?
  score       Int?
  feedback    String?            @db.Text
  startedAt   DateTime           @default(now())
  completedAt DateTime?

  @@index([userId])
}

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

model PortfolioArtifact {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String
  description        String   @db.Text
  contentUrl         String?
  skillsDemonstrated String[]
  aiReview           Json?
  isPublic           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

// ============================================
// AGENTIC AI - Action Execution
// ============================================

model PendingAction {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ActionType
  title       String
  description String       @db.Text
  params      Json
  status      ActionStatus @default(PENDING)
  confirmedAt DateTime?
  expiresAt   DateTime
  metadata    Json?
  createdAt   DateTime     @default(now())

  @@index([userId, status])
  @@index([expiresAt])
}

model ExecutedAction {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  type         ActionType
  title        String
  description  String          @db.Text
  params       Json
  result       Json?
  status       ExecutionStatus @default(SUCCESS)
  errorMessage String?         @db.Text
  executedAt   DateTime        @default(now())
  metadata     Json?

  @@index([userId])
  @@index([executedAt])
}

model JobApplication {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         String
  role            String
  jobUrl          String
  description     String?           @db.Text
  location        String?
  salaryRange     String?
  remote          Boolean           @default(false)
  status          ApplicationStatus @default(TRACKING)
  appliedAt       DateTime?
  followUpDate    DateTime?
  responseDate    DateTime?
  notes           String?           @db.Text
  resumeVersion   String?
  coverLetterId   String?
  calendarEventId String?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([status])
  @@index([appliedAt])
}

model CalendarEvent {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleEventId String?
  type          CalendarEventType
  title         String
  description   String?           @db.Text
  location      String?
  startTime     DateTime
  endTime       DateTime
  timezone      String            @default("UTC")
  attendees     String[]
  recurrence    String?
  reminders     Json?
  metadata      Json?
  status        EventStatus       @default(CONFIRMED)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId])
  @@index([startTime])
  @@index([status])
}

enum ActionType {
  SEND_EMAIL
  CREATE_CALENDAR_EVENT
  SCHEDULE_MENTORSHIP
  TRACK_JOB_APPLICATION
  SEND_NOTIFICATION
  UPDATE_PROGRESS
  GENERATE_DOCUMENT
}

enum ActionStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum ExecutionStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum ApplicationStatus {
  TRACKING
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
}

enum CalendarEventType {
  STUDY_SESSION
  INTERVIEW
  MENTORSHIP
  DEADLINE
  ASSESSMENT
  LIVE_SESSION
  CUSTOM
}

enum EventStatus {
  TENTATIVE
  CONFIRMED
  CANCELLED
  COMPLETED
}
